digraph A {
  Sources [shape=box];
  Errors [shape=box];
  Internals [shape=box];
  Configuration [color=red shape=box style=dashed];
  Sources -> Parser;
  Parser -> Internals;
  Internals -> Checker;
  Configuration -> Checker;
  Checker -> Errors;
  { rank=same; Sources Parser Internals Checker Errors }
}

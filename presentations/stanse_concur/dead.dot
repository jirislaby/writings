digraph CFG {
  { rank=same; ENTRY error }
  ENTRY [shape=box];
  EXIT [shape=box];
  fun1 [color=red];
  fun2 [color=red];
  ENTRY -> error;
  error -> empty_statement [label="true"];
  empty_statement -> return;
  error -> return [label="false"];
  return -> EXIT;
  fun1 -> fun2;
  fun2 -> EXIT;
}

<automaton>
  <description name="my simple checker" desc="n/a" />
  <start state="U" />

  <transition from="U[A]" by="lock[A]" to="L[A]" />
  <transition from="L[A]" by="unlock[A]" to="U[A]" />

  <error from="U[A]" by="unlock[A]" desc="double unlock"
    level="0" entry="entry" begin="start" propag="middle" end="end" />
  <error from="L[A]" by="lock[A]" desc="double lock"
    level="0" entry="entry" begin="start" propag="middle" end="end" />
  <error from="L[*]" by="" desc="leaving with lock"
    level="0" entry="entry" begin="start" propag="middle" end="end" />

  <pattern name="lock">
    <functionCall>
      <id>lock</id>
    </functionCall>
  </pattern>
  <pattern name="unlock">
    <functionCall>
      <id>unlock</id>
    </functionCall>
  </pattern>
</automaton>

* init

subscribe area
 struct sze2_subscribe_area {
	__u32 rx_areas;		/**< bitmap of areas to be subscribed
				     ~0U = all avaliable, corrected value
				     is in mmio space after this ioctl */
	__u32 tx_areas;		/**< see above */
	__u32 rx_poll_thresh;	/**< minimal count which will wake the
				     application from poll sleep */
	__u32 tx_poll_thresh;	/**< see above */
 };


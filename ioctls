#define SZE2_IOC_BASE		0xc0

#define SZE2_IOC_SUBSCRIBE_IFACE _IOW(SZE2_IOC_BASE, 0, \
		struct sze2_subscribe_iface)
#define SZE2_IOC_START		_IO  (SZE2_IOC_BASE, 1)
#define SZE2_IOC_LOCKDATA	_IOW (SZE2_IOC_BASE, 2, __u64)
#define SZE2_IOC_UNLOCKDATA	_IO  (SZE2_IOC_BASE, 3)
#define SZE2_IOC_REQUEST_SPC	_IORW(SZE2_IOC_BASE, 4, struct sze2_request_spc)
#define SZE2_IOC_PUTDATA	_IORW(SZE2_IOC_BASE, 5, struct sze2_put_data)
#define SZE2_IOC_STOP		_IO  (SZE2_IOC_BASE, 6)

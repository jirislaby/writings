#define SZE2_IOC_BASE		0xc0

#define SZE2_IOC_SUBSCRIBE_IFACE _IOW(SZE2_IOC_BASE, 0, \
		struct sze2_subscribe_area)
#define SZE2_IOC_START		_IO  (SZE2_IOC_BASE, 1)
#define SZE2_IOC_LOCKDATA	_IOWR(SZE2_IOC_BASE, 2, __u32)
#define SZE2_IOC_UNLOCKDATA	_IO  (SZE2_IOC_BASE, 3)
#define SZE2_IOC_REQUEST_SPACE	_IOWR(SZE2_IOC_BASE, 4, \
		struct sze2_request_space)
#define SZE2_IOC_PUTDATA	_IOWR(SZE2_IOC_BASE, 5, struct sze2_put_data)
#define SZE2_IOC_STOP		_IO  (SZE2_IOC_BASE, 6)

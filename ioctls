#define SZE2_MMIO_RX		0
#define SZE2_MMIO_TX		1
#define SZE2_MMIO_MAX		10
struct sze2_instance_info {
	__u64 reserved;			/**< for future/testing purposes */
	__u64 offsets[SZE2_MMIO_MAX];	/**< offset of each mmio space */
	__u64 sizes[SZE2_MMIO_MAX];	/**< size of each mmio space */
	__u32 rx_areas, tx_areas;	/**< subscribed areas */
	__u64 reserved[5];		/**< reserved for future purpose */
	struct {
		__u64 offset;		/**< offset of locked data */
		__u32 size;		/**< size of locked data */
	} adesc[2][0];			/**< for each area and direction */
};


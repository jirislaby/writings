#define SZE2_MMIO_RX		0
#define SZE2_MMIO_TX		1
#define SZE2_MMIO_RXDESC	2
#define SZE2_MMIO_MAX		10
struct sze2_instance_info {
	__u64 reserved;
	__u64 offsets[SZE2_MMIO_MAX];	/**< offset of each mmio space */
	__u64 sizes[SZE2_MMIO_MAX];	/**< size of each mmio space */
	__u32 interfaces;		/**< subscribed interfaces */
};

